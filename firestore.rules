rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /admins/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if isAdmin();
    }

    match /members/{memberId} {
      allow read, write: if isAdmin();
    }

    match /attendance/{date} {
      allow read, write: if isAdmin();
    }

    match /departments/{deptId} {
      allow read, write: if isAdmin();
    }

    match /leaves/{leaveId} {
      allow read, write: if isAdmin();
    }

    match /visitors/{visitorId} {
      allow read, write: if isAdmin();
    }

    match /followUps/{followUpId} {
      allow read, write: if isAdmin();
    }

    // Birthday greetings queued for human review before sending.
    // Admins read, edit the draft, and skip; the Cloud Function (admin SDK)
    // creates them and marks them sent.
    match /birthdayGreetings/{greetingId} {
      allow read, write: if isAdmin();
    }
  }
}
